# Database
DATABASE_URL=postgres://user:password@host/db
NEXT_PUBLIC_SERVER_URL=https://fromthetrunk.com

# Auth.js
NEXTAUTH_URL=https://fromthetrunk.com
NEXTAUTH_SECRET=your-nextauth-secret

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@fromthetrunk.com

# Cron Jobs
CRON_SECRET=generate-a-random-secret-for-cron

# Admin API
ADMIN_API_SECRET=generate-a-random-admin-secret

# ElectricSQL shape endpoint
# Example: https://your-electric-domain
NEXT_PUBLIC_ELECTRIC_SHAPE_URL=

# AI / embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
