# Database
DATABASE_URL=postgres://user:password@host/db
NEXT_PUBLIC_SERVER_URL=https://fromthetrunk.com

# Auth.js
NEXTAUTH_URL=https://fromthetrunk.com
NEXTAUTH_SECRET=your-nextauth-secret

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@fromthetrunk.com
ORDER_NOTIFICATION_EMAILS=hello@fromthetrunk.com,abraham.boodala@fromthetrunk.shop

# Email (SMTP fallback, for Google Workspace app passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=From the Trunk <hello@fromthetrunk.com>

# Cron Jobs
CRON_SECRET=generate-a-random-secret-for-cron

# Admin API
ADMIN_API_SECRET=generate-a-random-admin-secret

# ElectricSQL shape endpoint
# Example: https://your-electric-domain
NEXT_PUBLIC_ELECTRIC_SHAPE_URL=

# Analytics
NEXT_PUBLIC_GTM_ID=

# AI / embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_IMAGE_MODEL=gpt-image-2

# AI assistant (product creation copilot)
ANTHROPIC_API_KEY=

# Slack Xeno agent (socket bridge — runs locally, not on Vercel)
XENO_SLACK_AGENT_ENABLED=false
XENO_SLACK_ALLOWED_CHANNEL_IDS=
XENO_SLACK_ALLOW_DMS=true
XENO_WEAVE_X_CHANNEL_ID=C0B4S6V22LE
XENO_CODEX_MODEL=
XENO_CODEX_SANDBOX=read-only
XENO_CODEX_WORKDIR=
XENO_CODEX_TIMEOUT_MS=180000
XENO_CODEX_EPHEMERAL=true
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_BOT_USER_ID=
SLACK_CLI_APP_ID=
SLACK_CLI_TEAM_ID=
SLACK_CLI_PROJECT_DIR=
# WEAVE_X_SUPPLEMENTAL_CONTEXT: confidential owner map / question assignments.
# Set in .env.local (gitignored) when running the socket bridge locally.
# Never set in production. See lib/ai/xeno-local-config.example.ts for usage.
WEAVE_X_SUPPLEMENTAL_CONTEXT=
