# ──────────────────────────────────────────────────────────────
# From the Trunk — Example environment variables (local development)
# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# For the full production list see `.env.production.example`.
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# ─── Application ──────────────────────────────────────────────
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Auth (NextAuth) ─────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-32-char-string

# ─── Analytics ─────────────────────────────────────────────────
# Google Tag Manager container id — public, inlined into the client bundle.
# Leave blank to fully disable client analytics: no GTM, no GA4, and no consent
# banner render. GA4 is configured INSIDE the GTM container (no gtag.js in code,
# browser → GTM → GA4). Do NOT add NEXT_PUBLIC_GA4_MEASUREMENT_ID.
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXXX"

# Server-side GA4 Measurement Protocol (server-only). Currently forwards
# `payment_completed` as the backend conversion (NOT yet a GA4 `purchase`).
# GA4_MEASUREMENT_ID is a public id; GA4_API_SECRET is a SERVER-ONLY secret —
# never expose it to the browser (no NEXT_PUBLIC_ prefix).
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
GA4_API_SECRET="replace-with-server-only-ga4-api-secret"
