# Database
DATABASE_URL=postgres://user:password@host/db
NEXT_PUBLIC_SERVER_URL=https://fromthetrunk.com

# Auth.js
NEXTAUTH_URL=https://fromthetrunk.com
NEXTAUTH_SECRET=your-nextauth-secret

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@fromthetrunk.com
ORDER_NOTIFICATION_EMAILS=hello@fromthetrunk.com,abraham.boodala@fromthetrunk.shop

# Email (SMTP fallback, for Google Workspace app passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=From the Trunk <hello@fromthetrunk.com>

# Cron Jobs
CRON_SECRET=generate-a-random-secret-for-cron

# Error tracking — optional. When set, server errors are forwarded to Sentry.
# Leave empty to use the no-op tracker (default). Requires @sentry/nextjs when wired.
# DSN format: https://<public_key>@o<org>.ingest.sentry.io/<project_id>
SENTRY_DSN=

# Admin API
ADMIN_API_SECRET=generate-a-random-admin-secret

# ElectricSQL shape endpoint
# Example: https://your-electric-domain
NEXT_PUBLIC_ELECTRIC_SHAPE_URL=

# Analytics
NEXT_PUBLIC_GTM_ID=

# Structured logger
# Level filter: "debug" | "info" | "warn" | "error" (default: "info").
# "debug" shows all output; omit or set to "info" for normal operation.
LOG_LEVEL=info

# CMS preview (P3-06)
# Optional dedicated secret for signing CMS draft-preview tokens.
# Falls back to NEXTAUTH_SECRET when unset. Set to a random 32-char string
# if you want preview tokens to be invalidated independently of auth sessions.
CMS_PREVIEW_SECRET=

# Feature flags
# Set to "true" to enable GST-inclusive pricing (pricePaise treated as all-in price).
# Default is off. Flip only after the corresponding product-data migration is complete.
FTT_FEATURE_GST_INCLUSIVE=false
# Set to "true" to use the inventory-v2 reservations-based claim (quantity_available
# + reservations table). Default off = current stock_status claim. Flip only after the
# inventory-v2 migration (drizzle/0004) is applied + rehearsed.
FTT_FEATURE_INVENTORY_V2=false
# Set to "true" to render the homepage (/) via the block-content engine
# (P3-10 proof-of-concept). Default off = current hardcoded JSX (no change).
# Flip only after scripts/seed-homepage-cms.ts has been run + verified in staging.
FTT_FEATURE_BLOCKS_HOMEPAGE=false

# Rate limiting — optional durable backend (Upstash). When BOTH are set, the
# durable adapter is used; otherwise the in-memory limiter (default) applies.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-side analytics sinks (optional; internal-events table is always on).
# GA4 Measurement Protocol + Meta CAPI fire only when their vars are set; share
# event_id with the client pixel for dedup.
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
META_CAPI_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Channel health metrics — pull adapters (P5-04).
# When absent the adapter returns typed-zero; Control Centre shows empty states.
# Search Console (indexed pages, top queries, CTR)
GSC_SERVICE_ACCOUNT_JSON=
GSC_PROPERTY=
# GA4 Data API — sessions, conversions, revenue (distinct from GA4 Measurement Protocol above)
GA4_PROPERTY_ID=
GA4_DATA_SA_JSON=
# Vercel Insights — CWV p75 (LCP/INP/CLS) + deploy markers
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
# Meta Marketing — catalog item count + disapprovals (distinct from Meta CAPI above)
META_CATALOG_ID=
META_SYSTEM_USER_TOKEN=

# AI / embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_IMAGE_MODEL=gpt-image-2

# AI assistant (product creation copilot)
ANTHROPIC_API_KEY=

# Slack Xeno agent (socket bridge — runs locally, not on Vercel)
XENO_SLACK_AGENT_ENABLED=false
XENO_SLACK_ALLOWED_CHANNEL_IDS=
XENO_SLACK_ALLOW_DMS=true
XENO_WEAVE_X_CHANNEL_ID=C0B4S6V22LE
XENO_CODEX_MODEL=
XENO_CODEX_SANDBOX=read-only
XENO_CODEX_WORKDIR=
XENO_CODEX_TIMEOUT_MS=180000
XENO_CODEX_EPHEMERAL=true
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_BOT_USER_ID=
SLACK_CLI_APP_ID=
SLACK_CLI_TEAM_ID=
SLACK_CLI_PROJECT_DIR=
# WEAVE_X_SUPPLEMENTAL_CONTEXT: confidential owner map / question assignments.
# Set in .env.local (gitignored) when running the socket bridge locally.
# Never set in production. See lib/ai/xeno-local-config.example.ts for usage.
WEAVE_X_SUPPLEMENTAL_CONTEXT=
