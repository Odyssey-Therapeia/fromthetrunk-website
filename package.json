{
  "name": "ftt-fromthetrunk",
  "version": "0.26.2",
  "description": "Curated collection of pre-loved luxury sarees with provenance.",
  "main": "index.js",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "next dev",
    "xeno:slack:socket": "node --env-file=.env.local --import tsx scripts/xeno-slack-socket-bridge.ts",
    "build": "next build",
    "start": "next start",
    "serve:lhci": "next start --hostname 127.0.0.1 --port 3000",
    "lhci": "pnpm run build && lhci autorun",
    "lhci:autorun": "lhci autorun",
    "lhci:mobile": "pnpm run build && FTT_LHCI_FORM_FACTOR=mobile lhci autorun",
    "lhci:desktop": "pnpm run build && FTT_LHCI_FORM_FACTOR=desktop lhci autorun",
    "lhci:admin:mobile": "pnpm run build && FTT_LHCI_SCOPE=admin FTT_LHCI_FORM_FACTOR=mobile lhci autorun",
    "lhci:admin:desktop": "pnpm run build && FTT_LHCI_SCOPE=admin FTT_LHCI_FORM_FACTOR=desktop lhci autorun",
    "lhci:matrix": "FTT_LHCI_SCOPE=public FTT_LHCI_FORM_FACTOR=mobile pnpm run lhci:autorun && FTT_LHCI_SCOPE=public FTT_LHCI_FORM_FACTOR=desktop pnpm run lhci:autorun && FTT_LHCI_SCOPE=admin FTT_LHCI_FORM_FACTOR=mobile pnpm run lhci:autorun && FTT_LHCI_SCOPE=admin FTT_LHCI_FORM_FACTOR=desktop pnpm run lhci:autorun",
    "verify": "pnpm run test && pnpm run lint && pnpm run build",
    "verify:ux": "pnpm run build && pnpm run lhci:matrix",
    "agent:check": "pnpm run verify && pnpm run lhci:matrix",
    "lint": "eslint .",
    "generate:icons": "node --import tsx scripts/generate-icons.ts",
    "demo:check": "node --import tsx scripts/demo-readiness.ts",
    "migrate:payload-to-drizzle": "node --import tsx scripts/archive/migrate-payload-to-drizzle.ts",
    "seed:payload": "node --env-file=.env.local --import tsx scripts/seed-payload.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Odyssey-Therapeia/FTT-fromthetrunk.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Odyssey-Therapeia/FTT-fromthetrunk/issues"
  },
  "homepage": "https://github.com/Odyssey-Therapeia/FTT-fromthetrunk#readme",
  "private": true,
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.67",
    "@assistant-ui/react": "^0.14.22",
    "@assistant-ui/react-ai-sdk": "^1.3.37",
    "@auth/drizzle-adapter": "^1.11.1",
    "@electric-sql/client": "^1.5.9",
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
