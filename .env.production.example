# ──────────────────────────────────────────────────────────────
# From the Trunk — Production Environment Variables
# Copy this file, fill in all values, and set in your deployment platform.
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (e.g., Neon, Supabase, Railway)
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# ─── Application ──────────────────────────────────────────────
# Canonical production origin used by SEO metadata, sitemap, robots, and llms.txt.
SITE_URL=https://www.fromthetrunk.shop
NEXT_PUBLIC_SERVER_URL=https://www.fromthetrunk.shop

# ─── Auth (NextAuth) ─────────────────────────────────────────
NEXTAUTH_URL=https://www.fromthetrunk.shop
NEXTAUTH_SECRET=generate-a-random-32-char-string

# ─── OAuth Providers ─────────────────────────────────────────
# At least one provider must be configured for sign-in to work.

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Azure AD (optional)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# Twitter/X (optional)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── Razorpay Payment Gateway ────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=From the Trunk <hello@fromthetrunk.shop>

# ─── Cron Jobs ────────────────────────────────────────────────
# Shared secret for authenticating cron endpoints.
# Used by /api/v2/cron/release-reservations (every 10 min via Vercel Cron).
CRON_SECRET=generate-a-random-secret-for-cron

# ─── Admin API ────────────────────────────────────────────────
# Secret for admin-only API endpoints (order status updates, etc.)
ADMIN_API_SECRET=generate-a-random-admin-secret

# ─── ElectricSQL ───────────────────────────────────────────────
# Base URL of your Electric shape service (optional fallback to polling).
NEXT_PUBLIC_ELECTRIC_SHAPE_URL=

# ─── AI / Embeddings ───────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Analytics ─────────────────────────────────────────────────
# Google Tag Manager container id. Public (inlined into the browser bundle).
# When unset, GTM/GA4 do not load at all and the consent banner never appears.
# GA4 is configured INSIDE the GTM container (browser → GTM → GA4, no gtag.js).
# Set the real container id in the deploy platform env (Vercel), not in this file.
# Do NOT add NEXT_PUBLIC_GA4_MEASUREMENT_ID.
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXXX"

# Server-side GA4 Measurement Protocol (server-only). Currently forwards
# `payment_completed` as the backend conversion (NOT yet a GA4 `purchase`).
# GA4_MEASUREMENT_ID is a public id; GA4_API_SECRET is a SERVER-ONLY secret —
# never expose it to the browser (no NEXT_PUBLIC_ prefix).
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
GA4_API_SECRET="replace-with-server-only-ga4-api-secret"

#NEW KEY
