# ──────────────────────────────────────────────────────────────
# From the Trunk — Production Environment Variables
# Copy this file, fill in all values, and set in your deployment platform.
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (e.g., Neon, Supabase, Railway)
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# ─── Application ──────────────────────────────────────────────
# Canonical production origin used by SEO metadata, sitemap, robots, and llms.txt.
SITE_URL=https://www.fromthetrunk.shop
NEXT_PUBLIC_SERVER_URL=https://www.fromthetrunk.shop

# ─── Auth (NextAuth) ─────────────────────────────────────────
NEXTAUTH_URL=https://www.fromthetrunk.shop
NEXTAUTH_SECRET=generate-a-random-32-char-string

# ─── OAuth Providers ─────────────────────────────────────────
# At least one provider must be configured for sign-in to work.

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Azure AD (optional)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# Twitter/X (optional)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── Razorpay Payment Gateway ────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=From the Trunk <hello@fromthetrunk.shop>

# ─── Cron Jobs ────────────────────────────────────────────────
# Shared secret for authenticating cron endpoints.
# Used by /api/v2/cron/release-reservations (every 10 min via Vercel Cron).
CRON_SECRET=generate-a-random-secret-for-cron

# ─── Admin API ────────────────────────────────────────────────
# Secret for admin-only API endpoints (order status updates, etc.)
ADMIN_API_SECRET=generate-a-random-admin-secret

# ─── ElectricSQL ───────────────────────────────────────────────
# Base URL of your Electric shape service (optional fallback to polling).
NEXT_PUBLIC_ELECTRIC_SHAPE_URL=

# ─── AI / Embeddings ───────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Analytics ─────────────────────────────────────────────────
# PostHog (primary product analytics — opt-in via cookie consent banner).
# Client key (public). Get it from PostHog → Project Settings → API Key.
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog Cloud host. Leave default unless self-hosting.
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# Server-side key (secret, NOT public) — enables the posthog-node sink for
# server events (order_created, payment_completed). Project Settings → API Key.
POSTHOG_KEY=

# GTM container id (optional). When set, GTM loads in <head> with a dataLayer
# init so Google Tag Assistant detects the container.
NEXT_PUBLIC_GTM_ID=
# GA4 measurement id for the client-side gtag (optional). Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# GA4 Measurement Protocol (server-side, optional). Distinct from the client id.
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
# Meta Conversions API (server-side, optional).
META_CAPI_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

#NEW KEY
